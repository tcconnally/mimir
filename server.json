{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Perseus-Computing-LLC/mimir",
  "title": "Mimir, persistent memory engine for AI agents",
  "description": "Local-first MCP memory server: SQLite, FTS5 and vector search, AES-256-GCM. 46 tools, no cloud.",
  "version": "2.7.0",
  "packages": [{
    "registryType": "oci",
    "identifier": "ghcr.io/perseus-computing-llc/mimir:2.7.0",
    "transport": {"type": "stdio"},
    "runtimeHint": "docker",
    "runtimeArguments": [
      {"type": "named", "name": "-i"},
      {"type": "named", "name": "--rm"},
      {"type": "named", "name": "-v", "value": "mimir-data:/data"}
    ],
    "packageArguments": [
      {"type": "positional", "value": "serve"},
      {"type": "positional", "value": "--db"},
      {"type": "positional", "value": "/data/mimir.db"}
    ]
  }],
  "websiteUrl": "https://github.com/Perseus-Computing-LLC/mimir",
  "repository": {
    "source": "github",
    "url": "https://github.com/Perseus-Computing-LLC/mimir"
  }
}
